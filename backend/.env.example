# =============================================================================
# CAMPUS NETWORK MONITOR - ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values

# JWT Configuration
JWT_SECRET_KEY=change-this-to-a-random-secret-key

# Email (SendGrid) - Optional
SENDGRID_API_KEY=
FROM_EMAIL=alerts@your-domain.com

# SMS (Twilio) - Optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Webhooks - Optional
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# Database
DATABASE_NAME=network_monitor.db

# Monitoring
MONITORING_INTERVAL=30
SNMP_COMMUNITY=public